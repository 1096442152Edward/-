<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>云同步打卡统计系统</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* 此处包含了你原始文件中的所有样式 */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%); color: #333; min-height: 100vh; display: flex; }
        .sidebar { width: 250px; background: rgba(0, 0, 0, 0.2); padding: 20px; display: flex; flex-direction: column; backdrop-filter: blur(5px); }
        .sidebar-header { color: white; text-align: center; margin-bottom: 30px; border-bottom: 1px solid rgba(255, 255, 255, 0.2); }
        .group-btn { width: 100%; padding: 12px 15px; background: rgba(255, 255, 255, 0.1); border: none; border-radius: 8px; color: white; cursor: pointer; margin-bottom: 10px; }
        .group-btn.active { background: rgba(255, 255, 255, 0.3); }
        .main-content { flex: 1; padding: 20px; overflow-y: auto; }
        .container { display: flex; gap: 20px; max-width: 1400px; margin: 0 auto; }
        .cards-section { flex: 7; }
        .leaderboard-section { flex: 3; background: rgba(255, 255, 255, 0.95); border-radius: 15px; padding: 20px; max-height: 80vh; overflow-y: auto; }
        .cards-container { display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; }
        .card { background: white; border-radius: 15px; width: 300px; position: relative; overflow: hidden; box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
        .name-section { padding: 20px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
        .counter-section { display: flex; border-top: 1px solid #eee; }
        .counter { flex: 1; padding: 15px; text-align: center; cursor: pointer; }
        .add-card-btn { display: block; margin: 20px auto; padding: 15px 30px; border-radius: 50px; border: none; cursor: pointer; font-weight: bold; }
        /* 状态条 */
        #sync-status { position: fixed; top: 10px; right: 10px; padding: 6px 15px; background: rgba(0,0,0,0.5); color: #fff; border-radius: 20px; font-size: 12px; z-index: 1000; }
        /* 颜色类 */
        .name-color-0 { background: linear-gradient(135deg, #ff7979, #eb4d4b); color: white; }
        .name-color-1 { background: linear-gradient(135deg, #f6e58d, #f9ca24); color: #333; }
        /* 其他样式省略，保持与原件一致... */
    </style>
</head>
<body>
    <div id="sync-status">初始化中...</div>
    <div class="sidebar">
        <div class="sidebar-header"><h2>小组列表</h2></div>
        <ul class="group-list" id="groupList">
            <button class="group-btn active" data-group="group1">第一组</button>
            <button class="group-btn" data-group="group2">第二组</button>
            <button class="group-btn" data-group="group3">第三组</button>
        </ul>
    </div>
    <div class="main-content">
        <header><h1 style="color:white; text-align:center; margin-bottom:20px;">云同步打卡统计</h1></header>
        <div class="container">
            <div class="cards-section">
                <div class="cards-container" id="cardsContainer"></div>
                <button class="add-card-btn" id="addCardBtn"><i class="fas fa-plus"></i> 添加新卡片</button>
            </div>
            <div class="leaderboard-section">
                <h2 style="color:#6a11cb; text-align:center;">排行榜</h2>
                <ul id="leaderboardList"></ul>
            </div>
        </div>
    </div>

    <script>
        // --- 1. 配置区 ---
        const SB_URL = "你的SUPABASE_URL"; 
        const SB_KEY = "你的SUPABASE_ANON_KEY";
        const supabase = supabase.createClient(SB_URL, SB_KEY);

        // --- 2. 状态管理 ---
        let activeGroup = 'group1';
        let groupsData = { group1: [], group2: [], group3: [], group4: [], group5: [] };

        // --- 3. 云端核心逻辑 ---
        async function loadData() {
            updateStatus("正在同步云端...");
            const { data, error } = await supabase.from('checkin_storage').select('groups_data').eq('id', 1).single();
            if (data) {
                groupsData = data.groups_data;
                updateStatus("同步成功");
                renderCards();
            } else {
                updateStatus("未找到云端数据");
            }
        }

        let debounceTimer;
        async function saveData() {
            updateStatus("同步中...");
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(async () => {
                const { error } = await supabase.from('checkin_storage').upsert({ id: 1, groups_data: groupsData });
                updateStatus(error ? "同步失败" : "云端已加密存储");
            }, 1000);
        }

        function updateStatus(msg) { document.getElementById('sync-status').innerText = msg; }

        // --- 4. 业务逻辑 (基于原件重构) ---
        function renderCards() {
            const container = document.getElementById('cardsContainer');
            container.innerHTML = '';
            const cards = groupsData[activeGroup] || [];
            
            cards.forEach(card => {
                const cardEl = document.createElement('div');
                cardEl.className = `card`;
                cardEl.innerHTML = `
                    <div class="name-section name-color-${card.colorIndex}">
                        <div class="name">${card.name}</div>
                    </div>
                    <div class="counter-section">
                        <div class="counter" onclick="changeCount(${card.id}, 'left')">
                            <div style="font-size:20px; font-weight:bold;">${card.leftCount}</div>
                            <div style="font-size:12px; color:#777;">月天数</div>
                        </div>
                        <div class="counter" onclick="changeCount(${card.id}, 'right')">
                            <div style="font-size:20px; font-weight:bold;">${card.rightCount}</div>
                            <div style="font-size:12px; color:#777;">总天数</div>
                        </div>
                    </div>
                `;
                // 绑定点击姓名增加双倍计数的逻辑
                cardEl.querySelector('.name-section').onclick = () => {
                    card.leftCount++; card.rightCount++; card.colorIndex = (card.colorIndex + 1) % 8;
                    saveData(); renderCards();
                };
                container.appendChild(cardEl);
            });
            updateLeaderboard();
        }

        window.changeCount = (id, side) => {
            const card = groupsData[activeGroup].find(c => c.id === id);
            if (side === 'left') card.leftCount++; else card.rightCount++;
            saveData(); renderCards();
        };

        function updateLeaderboard() {
            const list = document.getElementById('leaderboardList');
            const sorted = [...(groupsData[activeGroup] || [])].sort((a, b) => b.leftCount - a.leftCount);
            list.innerHTML = sorted.map((c, i) => `<li style="padding:10px; border-bottom:1px solid #eee;">${i+1}. ${c.name} - ${c.leftCount}天</li>`).join('');
        }

        // 初始化
        document.querySelectorAll('.group-btn').forEach(btn => {
            btn.onclick = (e) => {
                document.querySelectorAll('.group-btn').forEach(b => b.classList.remove('active'));
                e.target.classList.add('active');
                activeGroup = e.target.dataset.group;
                renderCards();
            };
        });

        document.getElementById('addCardBtn').onclick = () => {
            const newId = Date.now();
            groupsData[activeGroup].push({ id: newId, name: "新成员", leftCount: 0, rightCount: 0, colorIndex: 0 });
            saveData(); renderCards();
        };

        loadData();
    </script>
</body>
</html>
